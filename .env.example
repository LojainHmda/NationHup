# Copy to `.env` and fill in real values. Never commit `.env` or key files.
# See DEPLOYMENT.md for deployment-specific notes.

NODE_ENV=development
PORT=5001

# Required — PostgreSQL (e.g. Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/DATABASE?sslmode=require

# Required — session signing (use a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_SECURE=false

# Public base URL (optional; used for absolute media URLs)
PUBLIC_APP_URL=
VITE_PUBLIC_APP_URL=

# Google OAuth (customer login) — from Google Cloud Console OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google service account JSON (single-line or minified) — Drive / server features; keep out of git
GOOGLE_CREDS_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# Cloudinary — product / brand images
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI assistant — use one of these depending on host (Replit vs direct OpenAI)
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional — Cloudflare (if used for media / R2)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Replit (set automatically on Replit)
REPLIT_DEV_DOMAIN=
REPL_ID=
